# Rust
http_archive(
    name = "rules_rust",
    sha256 = "401d8122d057778b00693a105f9392e62244243d6396e95b77c570f803f290b2",
    urls = ["https://github.com/bazelbuild/rules_rust/releases/download/0.31.0/rules_rust-v0.31.0.tar.gz"],
)

