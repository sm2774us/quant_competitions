workspace(name = "algothon_2026")

load("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

# ============================================================================
# rules_python — Python 3.13 toolchain
# ============================================================================
http_archive(
    name       = "rules_python",
    sha256     = "9d04041ac92a0985e344235f5d946f71ac543f1b1565f2cdbc9a2aaee8adf55b",
    strip_prefix = "rules_python-0.37.0",
    url        = "https://github.com/bazelbuild/rules_python/releases/download/0.37.0/rules_python-0.37.0.tar.gz",
)

load("@rules_python//python:repositories.bzl", "py_repositories", "python_register_toolchains")
py_repositories()

python_register_toolchains(
    name           = "python_3_13",
    python_version = "3.13",
)

load("@python_3_13//:defs.bzl", "interpreter")

# ============================================================================
# pip dependencies
# ============================================================================
load("@rules_python//python:pip.bzl", "pip_parse")

pip_parse(
    name                      = "pip_deps",
    python_interpreter_target = interpreter,
    requirements_lock         = "//:requirements.txt",
)

load("@pip_deps//:requirements.bzl", "install_deps")
install_deps()

# ============================================================================
# rules_foreign_cc — Bazel drives CMake as a first-class build target.
#
# Key role: `bazel build //src/cpp:algothon_cpp_ext` invokes our
# CMakeLists.txt hermetically inside Bazel's sandbox, producing the
# nanobind .so/.pyd extension without any out-of-band cmake invocations.
#
# This is the pattern that makes Bazel the *single* compile/build gateway
# for the polyglot (Python + C++26) monorepo.
#
# SHA256 — verify with:
#   curl -sL <url> | sha256sum
# ============================================================================
http_archive(
    name         = "rules_foreign_cc",
    sha256       = "476303bd0f1b04cc311fc258f1708a5f6ef82d3091e53fd1977fa20383425a6a",
    strip_prefix = "rules_foreign_cc-0.12.0",
    url          = "https://github.com/bazelbuild/rules_foreign_cc/releases/download/0.12.0/rules_foreign_cc-0.12.0.tar.gz",
)

load("@rules_foreign_cc//foreign_cc:repositories.bzl", "rules_foreign_cc_dependencies")
rules_foreign_cc_dependencies()

# ============================================================================
# Eigen 3.4.0 — header-only, SIMD-native linear algebra (AVX2 / AVX512).
#
# build_file_content creates cc_library("eigen") so that both the
# cmake() extension target and the native cc_test depend on the same node.
# ============================================================================
http_archive(
    name         = "eigen",
    sha256       = "b4c198460eba6f28d34894e3a5710998818515104d6e74e5cc331828c25749ee",
    strip_prefix = "eigen-3.4.0",
    url          = "https://gitlab.com/libeigen/eigen/-/archive/3.4.0/eigen-3.4.0.tar.gz",
    build_file_content = """\
cc_library(
    name       = "eigen",
    hdrs       = glob(["Eigen/**", "unsupported/**"]),
    includes   = ["."],
    copts      = ["-w"],
    visibility = ["//visibility:public"],
)
""",
)

# ============================================================================
# nanobind 2.2.0 — zero-overhead Python <-> C++26 bridge (zero-copy NumPy).
#
# Header-only target for IDE/cc_library depgraph.
# Full compilation occurs inside the cmake() sandbox via FetchContent,
# keeping build rules hermetic and matching the CMakeLists.txt exactly.
# ============================================================================
http_archive(
    name         = "nanobind",
    sha256       = "ce69822f34a8f17f6c6f5c9de38aa7490af2bb55e2fa6945e3ddb22e58e91d7d",
    strip_prefix = "nanobind-2.2.0",
    url          = "https://github.com/wjakob/nanobind/archive/refs/tags/v2.2.0.tar.gz",
    build_file_content = """\
cc_library(
    name       = "nanobind_headers",
    hdrs       = glob(["include/nanobind/**"]),
    includes   = ["include"],
    copts      = ["-w"],
    visibility = ["//visibility:public"],
)
""",
)

# ============================================================================
# GoogleTest 1.14.0 — C++ unit tests via native Bazel cc_test.
#
# Separation of concerns: Bazel owns testing (cc_test); CMake only builds
# the Python extension artifact (cmake()).
# ============================================================================
http_archive(
    name         = "googletest",
    sha256       = "8ad598c73ad796e0d8280b082cebd82a630d73e73cd3c70057938a6501bba5d7",
    strip_prefix = "googletest-1.14.0",
    url          = "https://github.com/google/googletest/archive/refs/tags/v1.14.0.tar.gz",
)
